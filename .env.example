# ========================
# Database
# ========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/interview_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/interview_db

# ========================
# Redis
# ========================
REDIS_URL=redis://localhost:6379/0

# ========================
# JWT Authentication
# ========================
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================
# AI / LLM APIs
# ========================
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# ========================
# Speech-to-Text
# ========================
OPENAI_API_KEY=your-openai-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key

# ========================
# Text-to-Speech
# ========================
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ========================
# Code Execution
# ========================
JUDGE0_API_KEY=your-judge0-api-key
JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com

# ========================
# Emotion Detection (Hume AI — optional)
# ========================
HUME_API_KEY=your-hume-api-key

# ========================
# Storage (AWS S3 or Supabase)
# ========================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=interview-recordings
AWS_REGION=ap-south-1

# ========================
# App Settings
# ========================
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
